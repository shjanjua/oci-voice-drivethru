# Copy to .env and fill. NEVER commit .env (gitignored).

# ---- language ----
MULTILINGUAL=true
DEFAULT_LANGUAGE=en        # en | es | fr | hi | de

# ---- OCI Generative AI: LLM + xAI Grok TTS (bearer key) ----
# Mint in the OCI Console: Analytics & AI > Generative AI > API Keys.
OCI_GENAI_API_KEY=
OCI_GENAI_REGION=us-ashburn-1
OCI_GENAI_LLM_MODEL=openai.gpt-oss-20b
OCI_GROK_VOICE=eve

# ---- OCI Speech: STT (auth via ~/.oci/config IAM signer, NOT the bearer key above) ----
# A valid ~/.oci/config (DEFAULT profile) must be present on the host. Set the compartment that owns
# your Speech usage; empty => the tenancy OCID (root compartment) from ~/.oci/config.
OCI_COMPARTMENT_ID=

# ---- pipeline turn-taking ----
PIPELINE_MIN_WORDS=2           # min words to accept a barge-in (rejects coughs/single words)

# ---- walk-off auto-reset (push-to-talk booth) ----
USER_AWAY_TIMEOUT=60           # seconds of silence before the booth auto-resets to idle.
                               # Empty/none/off => DISABLE.

# ---- per-tab room teardown (multi-user isolation) ----
KIOSK_TEARDOWN_GRACE=40        # seconds after the kiosk leaves before its room is torn down
                               # (must exceed a page-reload so a reload rejoins the same room)

# ---- menu ----
OUT_OF_STOCK=cortado

# ---- membership: Oracle ADB (optional — guest mode if unset) ----
DB_USER=voicedt
DB_PASSWORD=
DB_DSN=sjall_high
WALLET_DIR=./wallet           # absolute path recommended for services
WALLET_PASSWORD=

# ---- LiveKit (self-hosted) ----
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_PUBLIC_URL=           # empty for localhost; set for LAN/remote (browser -> public wss)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret     # matches `livekit-server --dev` built-in creds (devkey/secret)
